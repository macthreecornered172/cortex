# Stage 1: Build both Go binaries
FROM golang:1.22-alpine AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o /cortex-sidecar ./cmd/cortex-sidecar
RUN CGO_ENABLED=0 GOOS=linux go build -o /agent-worker ./cmd/agent-worker

# Stage 2: Minimal runtime with shell for entrypoint script
FROM alpine:3.19 AS runtime

ARG INSTALL_CLAUDE=0

RUN apk add --no-cache curl
RUN if [ "$INSTALL_CLAUDE" = "1" ]; then \
      apk add --no-cache nodejs npm && \
      npm install -g @anthropic-ai/claude-code && \
      claude --version; \
    fi

COPY --from=builder /cortex-sidecar /cortex-sidecar
COPY --from=builder /agent-worker /agent-worker
COPY scripts/entrypoint.sh /entrypoint.sh

RUN chmod +x /entrypoint.sh

RUN adduser -D -h /home/worker worker
USER worker

EXPOSE 9090

HEALTHCHECK --interval=5s --timeout=3s --retries=5 --start-period=10s \
  CMD curl -f http://localhost:${CORTEX_SIDECAR_PORT:-9090}/health || exit 1

ENTRYPOINT ["/entrypoint.sh"]
